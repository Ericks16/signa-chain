# ── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://signachain:password@localhost:5433/signachain_dev

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ── Blockchain ────────────────────────────────────────────────────────────────
# NEVER put a real private key here — use KMS/vault in production
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
CREDENTIAL_ANCHOR_ADDRESS=

# ── Key Management ────────────────────────────────────────────────────────────
# In production: point to KMS (AWS KMS, GCP KMS, HashiCorp Vault, etc.)
KMS_PROVIDER=local
KMS_LOCAL_KEYS_PATH=./keys  # only for development — never commit key files
KMS_LOCAL_MASTER_KEY=  # AES-256-GCM key, 32 bytes base64. Generate with: openssl rand -base64 32

# ── Redis (optional — only if rate limiting or sessions needed) ───────────────
# REDIS_URL=redis://localhost:6379

# ── Seed (dev bootstrap — single EPN issuer) ──────────────────────────────────
SEED_ISSUER_EMAIL=
SEED_ISSUER_PASSWORD=
SEED_ISSUER_NAME=Escuela Politécnica Nacional
SEED_ISSUER_LEGAL_NAME=Escuela Politécnica Nacional
SEED_ISSUER_COUNTRY=EC
SEED_ISSUER_WEBSITE=https://epn.edu.ec
